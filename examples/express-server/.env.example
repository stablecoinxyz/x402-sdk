# Base — always enabled
BASE_PAY_TO=0x...    # your EVM address on Base
# BASE_AMOUNT=1000000000000000   # 0.001 SBC (18 decimals)

# Radius — optional, set RADIUS_PAY_TO to enable
# RADIUS_PAY_TO=0x...            # your EVM address on Radius
# RADIUS_AMOUNT=1000             # 0.001 SBC (6 decimals)

# Solana — optional, set SOLANA_PAY_TO to enable
# SOLANA_PAY_TO=                 # your Solana address
# SOLANA_AMOUNT=1000000          # 0.001 SBC (9 decimals)

# API key — required for mainnet networks (get yours at dashboard.stablecoin.xyz)
API_KEY=sbc-...

# Testnet overrides (optional)
# BASE_NETWORK=base-sepolia
# RADIUS_NETWORK=radius-testnet
# SOLANA_NETWORK=solana-devnet

# Port (optional)
# PORT=4402
