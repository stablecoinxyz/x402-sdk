# Wallet private key (must hold SBC on Radius)
PRIVATE_KEY=0x...

# Radius RPC URL (required)
RPC_URL=

# API key — required when calling mainnet endpoints (get yours at dashboard.stablecoin.xyz)
# Note: for EVM, the server (express-server) uses the API key, not this client directly.
# API_KEY=sbc-...

# Optional overrides
# FACILITATOR_URL=https://x402.stablecoin.xyz
